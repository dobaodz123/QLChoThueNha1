@model IEnumerable<QlChoThueNha1.Models.RentalRequest>
@{
    ViewData["Title"] = "Yêu cầu của tôi";
}
<div class="container mt-5">
    <h3 class="mb-4 text-primary">📋 Yêu cầu thuê của tôi</h3>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> Bạn chưa có yêu cầu thuê nào.
            <a asp-controller="House" asp-action="Index" class="alert-link">Tìm nhà ngay!</a>
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nhà</th>
                    <th>Địa chỉ</th>
                    <th>Ngày bắt đầu</th>
                    <th>Ngày kết thúc</th>
                    <th>Ngày gửi</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.House?.Name</td>
                        <td>@item.House?.Address</td>
                        <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.RequestDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="badge bg-warning text-dark">
                                    ⏳ Chờ duyệt
                                </span>
                            }
                            else if (item.Status == "Approved")
                            {
                                <span class="badge bg-success">
                                    ✅ Đã chấp nhận
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    ❌ Từ chối
                                </span>
                            }
                        </td>
                        <td>@(item.Note ?? "-")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <a asp-controller="House" asp-action="Index" class="btn btn-primary mt-2">
        <i class="fas fa-search"></i> Tìm thêm nhà
    </a>
</div>