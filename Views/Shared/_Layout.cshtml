<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Cho Thuê Nhà</title>

    <!-- Bootstrap CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar {
            box-shadow: 0 2px 4px rgba(0,0,0,.1);
        }

        .card {
            transition: transform 0.3s, box-shadow 0.3s;
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 4px 12px rgba(0,0,0,.2);
            }

        .house-img {
            height: 200px;
            object-fit: cover;
        }

        footer {
            background: #2c3e50;
            color: white;
            padding: 40px 0 20px;
            margin-top: 50px;
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-home"></i> Thuê Nhà 24/7
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Trang chủ
                            </a>
                        </li>

                        <!-- ĐÃ SỬA LỖI Ở ĐÂY -->
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="House" asp-action="Index">
                                <i class="fas fa-search"></i> Tìm nhà
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="fas fa-tachometer-alt"></i> Quản trị
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle"></i>
                                    @User.FindFirst("FullName")?.Value
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">

                                    @if (User.IsInRole("Customer"))
                                    {
                                        <li>
                                            <a class="dropdown-item"
                                               asp-controller="RentalRequest"
                                               asp-action="MyRequests">
                                                <i class="fas fa-file-alt"></i> Yêu cầu của tôi
                                            </a>
                                        </li>
                                    }

                                    <li>
                                        <a class="dropdown-item"
                                           asp-controller="Account"
                                           asp-action="Profile">
                                            <i class="fas fa-user"></i> Hồ sơ
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider"></li>

                                    <li>
                                        <form method="post"
                                              asp-controller="Account"
                                              asp-action="Logout">
                                            <button type="submit"
                                                    class="dropdown-item text-danger">
                                                <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i> Đăng nhập
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2"
                                   asp-controller="Account"
                                   asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- BODY -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5><i class="fas fa-home"></i> Thuê Nhà 24/7</h5>
                    <p>Nền tảng cho thuê nhà uy tín, nhanh chóng và an toàn.</p>
                </div>

                <div class="col-md-4">
                    <h5>Liên kết</h5>
                    <ul class="list-unstyled">
                        <li>
                            <a asp-controller="Home"
                               asp-action="Index"
                               class="text-white-50">
                                Trang chủ
                            </a>
                        </li>

                        <!-- ĐÃ SỬA LỖI Ở ĐÂY -->
                        <li>
                            <a asp-controller="House"
                               asp-action="Index"
                               class="text-white-50">
                                Tìm nhà
                            </a>
                        </li>

                        <li>
                            <a asp-controller="Home"
                               asp-action="About"
                               class="text-white-50">
                                Về chúng tôi
                            </a>
                        </li>
                    </ul>
                </div>

                <div class="col-md-4">
                    <h5>Liên hệ</h5>
                    <p class="text-white-50">
                        <i class="fas fa-phone"></i> 0123-456-789<br>
                        <i class="fas fa-envelope"></i> contact@thuenha247.vn
                    </p>
                </div>
            </div>

            <hr class="bg-white-50">

            <div class="text-center text-white-50">
                <p>&copy; 2026 - Quản Lý Cho Thuê Nhà - Bài tập lớn C#</p>
            </div>
        </div>
    </footer>

    <!-- JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>