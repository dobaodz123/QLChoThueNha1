@model IEnumerable<QlChoThueNha1.Models.HouseType>

<h2>Quản lý loại nhà</h2>
<a asp-action="Create" class="btn btn-primary">Thêm loại nhà</a>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tên loại</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>