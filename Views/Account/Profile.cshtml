@model QlChoThueNha1.Models.User
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="container py-5" style="max-width:600px;">
    <div class="card p-4">
        <div class="text-center mb-4">
            <div style="width:80px;height:80px;background:linear-gradient(135deg,#1a6cff,#4d9fff);
                        border-radius:50%;display:flex;align-items:center;justify-content:center;
                        margin:0 auto 12px;font-size:32px;color:white;">
                <i class="fas fa-user"></i>
            </div>
            <h4 class="fw-700 mb-0">@Model.FullName</h4>
            <small class="text-muted">@Model.Email</small>
            <span class="badge ms-2" style="background:#1a6cff;">@Model.Role</span>
        </div>

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-600">Họ và tên</label>
                <input type="text" name="FullName" value="@Model.FullName"
                       class="form-control" placeholder="Nhập họ tên..." />
            </div>

            <div class="mb-3">
                <label class="form-label fw-600">Email</label>
                <input type="text" value="@Model.Email"
                       class="form-control" readonly style="opacity:0.6;" />
                <small class="text-muted">Email không thể thay đổi</small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-600">Số điện thoại</label>
                <input type="text" name="Phone" value="@Model.Phone"
                       class="form-control" placeholder="Nhập số điện thoại..." />
            </div>

            <div class="mb-4">
                <label class="form-label fw-600">Mật khẩu mới</label>
                <input type="password" name="Password"
                       class="form-control" placeholder="Để trống nếu không đổi..." />
            </div>

            <div class="mb-3 text-muted" style="font-size:0.85rem;">
                <i class="fas fa-calendar-alt me-1"></i>
                Ngày tham gia: @Model.CreatedAt?.ToString("dd/MM/yyyy")
            </div>

            <button type="submit" class="btn w-100"
                    style="background:linear-gradient(135deg,#1a6cff,#4d9fff);color:white;
                           border-radius:12px;padding:12px;font-weight:600;">
                <i class="fas fa-save me-2"></i>Lưu thay đổi
            </button>
        </form>
    </div>
</div>