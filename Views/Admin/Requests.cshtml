@model IEnumerable<dynamic>

<h2>Danh sách yêu cầu thuê</h2>

<table border="1">
    @foreach (var r in Model)
    {
        <tr>
            <td>@(r.House?.Name)</td>
            <td>@r.TenantName</td>
            <td>@r.Status</td>
            <td>
                @if ((r.Status as string) == "pending")
                {
                    
                }
            </td>
        </tr>
    }
</table>
