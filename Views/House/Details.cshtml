@model QlChoThueNha1.Models.House
@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.jpg" : Model.ImageUrl)"
                     class="card-img-top" alt="@Model.Name" style="height: 400px; object-fit: cover;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h2 class="fw-bold">@Model.Name</h2>
                        @if (Model.Status == "Available")
                        {
                            <span class="status-available">
                                <i class="fas fa-check-circle"></i> Còn trống
                            </span>
                        }
                        else
                        {
                            <span class="status-rented">
                                <i class="fas fa-times-circle"></i> Đã thuê
                            </span>
                        }
                    </div>

                    <div class="mb-4">
                        <h3 class="text-primary">@Model.Price.ToString("N0") đ/tháng</h3>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p>
                                <i class="fas fa-map-marker-alt text-primary"></i>
                                <strong>Địa chỉ:</strong> @Model.Address
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p>
                                <i class="fas fa-layer-group text-primary"></i>
                                <strong>Loại nhà:</strong> @Model.HouseType?.Name
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p>
                                <i class="fas fa-ruler-combined text-primary"></i>
                                <strong>Diện tích:</strong> @Model.Area m²
                            </p>
                        </div>
                    </div>

                    <h4 class="mt-4">Mô tả</h4>
                    <p class="text-muted">@Model.Description</p>

                    @if (Model.Status == "Available" && User.IsInRole("Customer"))
                    {
                        <div class="mt-4">
                            <a asp-controller="RentalRequest" asp-action="Create" asp-route-houseId="@Model.Id"
                               class="btn btn-primary btn-lg w-100">
                                <i class="fas fa-paper-plane"></i> Gửi yêu cầu thuê nhà này
                            </a>
                        </div>
                    }
                    else if (!User.Identity.IsAuthenticated)
                    {
                        <div class="alert alert-info">
                            Vui lòng <a asp-controller="Account" asp-action="Login">đăng nhập</a>
                            để gửi yêu cầu thuê nhà.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Thông tin liên hệ</h5>
                </div>
                <div class="card-body">
                    <p><i class="fas fa-user"></i> <strong>Chủ nhà:</strong> Admin</p>
                    <p><i class="fas fa-phone"></i> <strong>SĐT:</strong> 0123-456-789</p>
                    <p><i class="fas fa-envelope"></i> <strong>Email:</strong> admin@thuenha.vn</p>
                    <button class="btn btn-success w-100 mb-2">
                        <i class="fas fa-phone"></i> Gọi điện
                    </button>
                    <button class="btn btn-outline-primary w-100">
                        <i class="fas fa-envelope"></i> Gửi email
                    </button>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="fw-bold">Lưu ý khi thuê:</h6>
                    <ul class="small text-muted">
                        <li>Đặt cọc 1 tháng tiền nhà</li>
                        <li>Thanh toán trước ngày 5 hàng tháng</li>
                        <li>Hợp đồng tối thiểu 6 tháng</li>
                        <li>Không nuôi thú cưng</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-controller="House" asp-action="Search" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>
</div>