<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Cho Thuê Nhà</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary: #1a6cff;
            --primary-dark: #0f4fd4;
            --accent: #ff6b35;
            --dark: #0d1117;
            --surface: #ffffff;
            --text: #1a1a2e;
            --text-muted: #6b7280;
            --border: rgba(0,0,0,0.08);
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background: #f4f6fb;
            color: var(--text);
        }

        /* ===== NAVBAR ===== */
        .navbar {
            background: rgba(255,255,255,0.92) !important;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            box-shadow: 0 2px 20px rgba(0,0,0,0.06);
            padding: 12px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--primary) !important;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: -0.3px;
        }

            .navbar-brand .brand-icon {
                width: 36px;
                height: 36px;
                background: linear-gradient(135deg, var(--primary), #4d9fff);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 16px;
                box-shadow: 0 4px 12px rgba(26,108,255,0.3);
            }

        .nav-link {
            color: var(--text-muted) !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 8px 14px !important;
            border-radius: 8px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .nav-link:hover {
                color: var(--primary) !important;
                background: rgba(26,108,255,0.08);
            }

            .nav-link.active {
                color: var(--primary) !important;
                background: rgba(26,108,255,0.1);
            }

            .nav-link i {
                font-size: 13px;
            }

        /* Dropdown */
        .dropdown-menu {
            border: none;
            border-radius: 14px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.12);
            padding: 8px;
            min-width: 200px;
            margin-top: 8px !important;
        }

        .dropdown-item {
            border-radius: 8px;
            padding: 9px 14px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-muted);
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .dropdown-item:hover {
                background: rgba(26,108,255,0.08);
                color: var(--primary);
            }

            .dropdown-item.text-danger:hover {
                background: rgba(255,59,59,0.08);
                color: #ff3b3b !important;
            }

        .dropdown-divider {
            margin: 6px 0;
        }

        /* Admin badge */
        .admin-link {
            color: #ff3b3b !important;
        }

            .admin-link:hover {
                background: rgba(255,59,59,0.08) !important;
                color: #ff3b3b !important;
            }

        /* Auth buttons */
        .btn-nav-login {
            color: var(--primary) !important;
            font-weight: 600;
            font-size: 0.875rem;
            padding: 8px 16px !important;
            border-radius: 8px;
            border: 1.5px solid rgba(26,108,255,0.3);
            transition: all 0.2s;
        }

            .btn-nav-login:hover {
                background: rgba(26,108,255,0.08);
                border-color: var(--primary);
            }

        .btn-nav-register {
            background: linear-gradient(135deg, var(--primary), #4d9fff);
            color: white !important;
            font-weight: 600;
            font-size: 0.875rem;
            padding: 8px 18px !important;
            border-radius: 8px;
            border: none;
            box-shadow: 0 4px 14px rgba(26,108,255,0.3);
            transition: all 0.2s;
        }

            .btn-nav-register:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(26,108,255,0.4);
            }

        /* User avatar chip */
        .user-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 30px;
            background: rgba(26,108,255,0.08);
            border: 1.5px solid rgba(26,108,255,0.15);
            transition: all 0.2s;
        }

            .user-chip:hover {
                background: rgba(26,108,255,0.12);
            }

        .user-avatar {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, var(--primary), #4d9fff);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
        }

        /* ===== TOAST ===== */
        .toast-container {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
        }

        .toast {
            border-radius: 12px !important;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15) !important;
            min-width: 280px;
        }

        /* ===== MAIN ===== */
        main {
            min-height: calc(100vh - 200px);
        }

        /* ===== FOOTER ===== */
        footer {
            background: var(--dark);
            color: rgba(255,255,255,0.7);
            padding: 50px 0 25px;
            margin-top: 60px;
        }

            footer h5 {
                color: white;
                font-weight: 700;
                margin-bottom: 16px;
                font-size: 1rem;
            }

            footer a {
                color: rgba(255,255,255,0.5);
                text-decoration: none;
                font-size: 0.875rem;
                transition: color 0.2s;
                display: block;
                margin-bottom: 6px;
            }

                footer a:hover {
                    color: white;
                }

            footer hr {
                border-color: rgba(255,255,255,0.1);
                margin: 30px 0 20px;
            }

        .footer-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }

        .footer-brand-icon {
            width: 38px;
            height: 38px;
            background: linear-gradient(135deg, var(--primary), #4d9fff);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 16px;
        }

        .footer-social {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }

            .footer-social a {
                width: 36px;
                height: 36px;
                background: rgba(255,255,255,0.08);
                border-radius: 8px;
                display: flex !important;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                margin: 0;
                transition: all 0.2s;
            }

                .footer-social a:hover {
                    background: var(--primary);
                    color: white;
                }

        /* Cards global */
        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 2px 16px rgba(0,0,0,0.07);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

            .card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 40px rgba(0,0,0,0.12);
            }
    </style>
</head>
<body>

    <!-- TOAST -->
    @if (TempData["Success"] != null)
    {
        <div class="toast-container">
            <div class="toast show align-items-center text-white bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body fw-500">
                        <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="toast-container">
            <div class="toast show align-items-center text-white bg-danger border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body fw-500">
                        <i class="fas fa-times-circle me-2"></i> @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        </div>
    }

    <!-- NAVBAR -->
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <div class="brand-icon"><i class="fas fa-home"></i></div>
                    Thuê Nhà 24/7
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto ms-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="House" asp-action="Index">
                                <i class="fas fa-search"></i> Tìm nhà
                            </a>
                        </li>


                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle admin-link fw-bold"
                                   href="#" data-bs-toggle="dropdown">
                                    <i class="fas fa-user-shield"></i> Quản trị
                                </a>
                                <ul class="dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-controller="HouseType" asp-action="Index">
                                            <i class="fas fa-list"></i> Quản lý loại nhà
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="House" asp-action="Index">
                                            <i class="fas fa-building"></i> Quản lý nhà
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="RentalRequest" asp-action="Index">
                                            <i class="fas fa-file-signature"></i> Quản lý yêu cầu thuê
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link user-chip dropdown-toggle text-decoration-none" href="#" data-bs-toggle="dropdown">
                                    <div class="user-avatar"><i class="fas fa-user" style="font-size:11px;"></i></div>
                                    <span style="font-size:0.875rem; font-weight:600; color:#1a1a2e;">
                                        @User.Identity.Name
                                    </span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    @if (User.IsInRole("Customer"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="RentalRequest" asp-action="MyRequests">
                                                <i class="fas fa-file-alt"></i> Yêu cầu của tôi
                                            </a>
                                        </li>
                                    }
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fas fa-user"></i> Hồ sơ
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-controller="Account" asp-action="Logout">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="fas fa-sign-out-alt"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn-nav-login" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn-nav-register" asp-controller="Account" asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
        <link rel="stylesheet" href="~/css/site.css" />
    </header>

    <!-- BODY -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="footer-brand">
                        <div class="footer-brand-icon"><i class="fas fa-home"></i></div>
                        <span style="color:white; font-weight:700; font-size:1.1rem;">Thuê Nhà 24/7</span>
                    </div>
                    <p style="font-size:0.875rem; line-height:1.7;">
                        Nền tảng cho thuê nhà uy tín, nhanh chóng và an toàn. Kết nối chủ nhà và người thuê hiệu quả.
                    </p>
                    <div class="footer-social">
                        <a href="https://www.facebook.com/Dobao.06?locale=vi_VN" target="_blank" title="Facebook">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://www.instagram.com/" target="_blank" title="Instagram">
                            <i class="fab fa-instagram"></i>
                        </a>
                        <a href="https://www.tiktok.com/vi-VN/" target="_blank" title="TikTok">
                            <i class="fab fa-tiktok"></i>
                        </a>
                        <a href="https://www.youtube.com/MrBeast" target="_blank" title="YouTube">
                            <i class="fab fa-youtube"></i>
                        </a>
                    </div>
                </div>
                <div class="col-md-4">
                    <h5>Liên kết nhanh</h5>
                    <a asp-controller="Home" asp-action="Index"><i class="fas fa-chevron-right me-2" style="font-size:10px;"></i>Trang chủ</a>
                    <a asp-controller="House" asp-action="Index"><i class="fas fa-chevron-right me-2" style="font-size:10px;"></i>Tìm nhà</a>
                    <a asp-controller="Home" asp-action="About"><i class="fas fa-chevron-right me-2" style="font-size:10px;"></i>Về chúng tôi</a>
                </div>
                <div class="col-md-4">
                    <h5>Liên hệ</h5>
                    <p style="font-size:0.875rem; line-height:2;">
                        <i class="fas fa-phone me-2" style="color:var(--primary);"></i> 0123-456-789<br>
                        <i class="fas fa-envelope me-2" style="color:var(--primary);"></i> contact@thuenha247.vn<br>
                        <i class="fas fa-map-marker-alt me-2" style="color:var(--primary);"></i> TP. Hồ Chí Minh
                    </p>
                </div>
            </div>
            <hr>
            <div class="text-center" style="font-size:0.8rem;">
                <p class="mb-0">© 2026 Thuê Nhà 24/7 — Bài tập lớn C#</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        setTimeout(function () {
            document.querySelectorAll('.toast').forEach(t => t.classList.remove('show'));
        }, 4000);

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 20) {
                navbar.style.boxShadow = '0 4px 30px rgba(0,0,0,0.1)';
            } else {
                navbar.style.boxShadow = '0 2px 20px rgba(0,0,0,0.06)';
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>