@model List<QlChoThueNha1.Models.RentalRequest>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid my-4">
    <h2 class="mb-4"><i class="fas fa-tachometer-alt"></i> Dashboard Quản Trị</h2>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">Tổng số nhà</h6>
                    <h2 class="mb-0">@ViewBag.TotalHouses</h2>
                    <small><i class="fas fa-home"></i> Tất cả nhà trong hệ thống</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title">Nhà còn trống</h6>
                    <h2 class="mb-0">@ViewBag.AvailableHouses</h2>
                    <small><i class="fas fa-check-circle"></i> Đang cho thuê</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h6 class="card-title">Đã cho thuê</h6>
                    <h2 class="mb-0">@ViewBag.RentedHouses</h2>
                    <small><i class="fas fa-lock"></i> Không còn trống</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h6 class="card-title">Yêu cầu chờ duyệt</h6>
                    <h2 class="mb-0">@ViewBag.PendingRequests</h2>
                    <small><i class="fas fa-clock"></i> Cần xử lý</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <a asp-controller="House" asp-action="Create" class="btn btn-primary w-100 py-3">
                <i class="fas fa-plus-circle fa-2x d-block mb-2"></i>
                Thêm nhà mới
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="ManageHouses" class="btn btn-info w-100 py-3">
                <i class="fas fa-home fa-2x d-block mb-2"></i>
                Quản lý nhà
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="ManageRequests" class="btn btn-warning w-100 py-3">
                <i class="fas fa-file-alt fa-2x d-block mb-2"></i>
                Quản lý yêu cầu
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Admin" asp-action="ManageHouseTypes" class="btn btn-secondary w-100 py-3">
                <i class="fas fa-layer-group fa-2x d-block mb-2"></i>
                Quản lý loại nhà
            </a>
        </div>
    </div>

    <!-- Recent Requests -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-history"></i> Yêu cầu thuê gần đây</h5>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Khách hàng</th>
                                <th>Nhà</th>
                                <th>Ngày gửi</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td>@request.User.FullName</td>
                                    <td>@request.House.Name</td>
                                    <td>@request.RequestDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (request.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Chờ duyệt</span>
                                        }
                                        else if (request.Status == "Approved")
                                        {
                                            <span class="badge bg-success">Đã duyệt</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Từ chối</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="RentalRequest" asp-action="Details"
                                           asp-route-id="@request.Id"
                                           class="btn btn-sm btn-outline-primary">
                                            Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted text-center mb-0">Chưa có yêu cầu nào</p>
            }
        </div>
    </div>
</div>